exports[`buildExportSource > snapshot of a small representative export 1`] = `
"// density.ts — generated by the density playground.
// Preview MUI density WITHOUT upgrading @mui/material — the unreleased preset
// logic is inlined as data; only stable public API is imported.
//
// REQUIRES <CssBaseline /> in the consuming app — it materialises the
// --mui-density-* vars these overrides reference. Without it the refs resolve
// to nothing and density silently does not apply.
//
// Usage:
//   const theme = enhanceCompactDensity(createTheme({ /* your options */ }));
//   <ThemeProvider theme={theme}><CssBaseline />…</ThemeProvider>
import { createTheme } from '@mui/material/styles';
import type { Theme } from '@mui/material/styles';

type AnyRecord = Record<string, any>;

// Per-preset payload, baked at export time — each preset carries ITS OWN
// playground edits (the playground keeps one override workspace per preset):
//   scale      → :root { --mui-density-*: <px> } (via MuiCssBaseline)
//   components → preset baseline emissions ⊕ that preset's edits (flat-array slots)
//   typography → the preset's own type reflow ⊕ that preset's typography edits
//   shape      → that preset's shape edits (borderRadius)
// Playground edits are marked inline: appended slot layers sit between
// "user overrides" comments; edited token leaves carry a "playground edit" tag.
const compact = {
  scale: {
    '--mui-density-xxs': '2px',
    '--mui-density-xs': '4px',
    '--mui-density-sm': '6px',
    '--mui-density-md': '8px',
    '--mui-density-lg': '12px',
    '--mui-density-xl': '18px',
    '--mui-density-xxl': '24px',
  },
  components: {
    MuiButton: {
      styleOverrides: {
        root: [
          {
            variants: [
              {
                props: {
                  size: 'small',
                },
                style: {
                  padding: 'var(--mui-density-xxs) var(--mui-density-sm)',
                },
              },
              {
                props: {
                  size: 'medium',
                },
                style: {
                  padding: 'var(--mui-density-xs) var(--mui-density-lg)',
                },
              },
              {
                props: {
                  size: 'large',
                },
                style: {
                  padding: 'var(--mui-density-sm) var(--mui-density-xl)',
                },
              },
            ],
          },
          // ─── user overrides (playground edits) — appended layer, wins by order ───
          {
            variants: [
              {
                props: {
                  size: 'small',
                },
                style: {
                  padding: 'var(--mui-density-xs)',
                },
              },
            ],
          },
          // ─── end user overrides ───
        ],
      },
    },
    MuiMenuItem: {
      styleOverrides: {
        root: [
          {
            fontSize: '0.875rem',
            lineHeight: 1.4,
            variants: [
              {
                props: {
                  dense: false,
                },
                style: {
                  minHeight: '36px',
                  paddingBlock: 'var(--mui-density-sm)',
                },
              },
              {
                props: {
                  dense: true,
                },
                style: {
                  minHeight: '28px',
                  paddingBlock: 'var(--mui-density-xs)',
                  '& .MuiListItemIcon-root svg': {
                    fontSize: '1.125rem',
                  },
                },
              },
              {
                props: {
                  dense: false,
                  disableGutters: false,
                },
                style: {
                  paddingInline: 'var(--mui-density-lg)',
                },
              },
              {
                props: {
                  dense: true,
                  disableGutters: false,
                },
                style: {
                  paddingInline: 'var(--mui-density-md)',
                },
              },
            ],
            '& .MuiListItemIcon-root': {
              minWidth: 28,
            },
          },
        ],
      },
    },
    MuiList: {
      styleOverrides: {
        root: [
          {
            variants: [
              {
                props: {
                  disablePadding: false,
                },
                style: {
                  paddingBlock: 'var(--mui-density-md)',
                },
              },
              {
                props: ({ ownerState }) => ownerState.subheader,
                style: {
                  paddingTop: 0,
                },
              },
            ],
          },
        ],
      },
    },
    MuiTooltip: {
      styleOverrides: {
        tooltip: [
          {
            fontSize: '0.625rem',
            padding: 'var(--mui-density-xxs) var(--mui-density-sm)',
            '.MuiTooltip-popper[data-popper-placement*="left"] &': {
              marginInlineEnd: 'var(--mui-density-lg)',
            },
            '.MuiTooltip-popper[data-popper-placement*="right"] &': {
              marginInlineStart: 'var(--mui-density-lg)',
            },
            '.MuiTooltip-popper[data-popper-placement*="top"] &': {
