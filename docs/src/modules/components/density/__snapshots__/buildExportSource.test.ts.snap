            padding: 'var(--mui-density-lg)',
            '&:last-child': {
              paddingBottom: 'var(--mui-density-xl)',
            },
          },
        ],
      },
    },
    MuiCardActions: {
      styleOverrides: {
        root: [
          {
            padding: 'var(--mui-density-sm)',
            variants: [
              {
                props: {
                  disableSpacing: false,
                },
                style: {
                  '& > :not(style) ~ :not(style)': {
                    marginLeft: 'var(--mui-density-sm)',
                  },
                },
              },
            ],
          },
        ],
      },
    },
    MuiCardHeader: {
      styleOverrides: {
        root: [
          {
            padding: 'var(--mui-density-lg)',
          },
        ],
        avatar: [
          {
            marginRight: 'var(--mui-density-lg)',
          },
        ],
        action: [
          {
            marginBlock: 'calc(var(--mui-density-xxs) * -1)',
            marginRight: 'calc(var(--mui-density-sm) * -1)',
          },
        ],
      },
    },
    MuiSelect: {
      styleOverrides: {
        select: [
          {
            minHeight: '28px',
          },
        ],
      },
    },
    MuiAlert: {
      styleOverrides: {
        root: [
          {
            paddingBlock: 'var(--mui-density-xs)',
            paddingInline: 'var(--mui-density-lg)',
          },
        ],
        icon: [
          {
            marginRight: 'var(--mui-density-md)',
          },
        ],
      },
    },
    MuiChip: {
      styleOverrides: {
        root: [
          {
            variants: [
              {
                props: {
                  size: 'medium',
                },
                style: {
                  '--_height': '36px',
                  height: 'var(--_height)',
                  '& .MuiChip-avatar': {
                    width: 'calc(var(--_height) - 8px)',
                    height: 'calc(var(--_height) - 8px)',
                  },
                  '& .MuiChip-icon': {
                    fontSize: 'calc(var(--_height) - 8px)',
                  },
                  '& .MuiChip-deleteIcon': {
                    fontSize: 'calc(var(--_height) - 10px)',
                  },
                },
              },
              {
                props: {
                  size: 'small',
                },
                style: {
                  '--_height': '28px',
                  height: 'var(--_height)',
                  '& .MuiChip-avatar': {
                    width: 'calc(var(--_height) - 6px)',
                    height: 'calc(var(--_height) - 6px)',
                  },
                  '& .MuiChip-icon': {
                    fontSize: 'calc(var(--_height) - 6px)',
                  },
                  '& .MuiChip-deleteIcon': {
                    fontSize: 'calc(var(--_height) - 8px)',
                  },
                },
              },
            ],
          },
        ],
        label: [
          {
            variants: [
              {
                props: {
                  size: 'medium',
                },
                style: {
                  paddingInline: 'var(--mui-density-md)',
                },
              },
              {
                props: {
                  size: 'small',
                },
                style: {
                  paddingInline: 'var(--mui-density-sm)',
                },
              },
            ],
          },
        ],
      },
    },
    MuiAccordionSummary: {
      styleOverrides: {
        root: [
          {
            minHeight: '56px',
            padding: '0 var(--mui-density-lg)',
            variants: [
              {
                props: ({
          ownerState
        }) => !ownerState.disableGutters,
                style: {
                  '&.Mui-expanded': {
                    minHeight: '76px',
                  },
                },
              },
            ],
          },
        ],
        content: [
          {
            marginBlock: 'var(--mui-density-md)',
            variants: [
              {
                props: ({
            ownerState
          }) => !ownerState.disableGutters,
                style: {
                  '&.Mui-expanded': {
                    marginBlock: 'var(--mui-density-lg)',
                  },
                },
              },
            ],
          },
        ],
      },
    },
    MuiAccordionDetails: {
      styleOverrides: {
        root: [
          {
            paddingBlockStart: 'var(--mui-density-sm)',
            paddingBlockEnd: 'var(--mui-density-lg)',
            paddingInline: 'var(--mui-density-lg)',
          },
        ],
      },
    },
  },
  typography: {
    button: {
      fontSize: '0.9375rem',
      lineHeight: 2,
    },
  },
  shape: {},
};

function mergeTypography(base: AnyRecord, patch: AnyRecord): AnyRecord {
  const out: AnyRecord = { ...base };
  for (const [variant, styles] of Object.entries(patch)) {
    out[variant] = { ...(out[variant] as AnyRecord), ...(styles as AnyRecord) };
  }
  return out;
}

function enhance(
  theme: Theme,
  p: {
    scale: Record<string, string>;
    components: AnyRecord;
    typography: AnyRecord;
    shape: AnyRecord;
  },
): Theme {
  const components: AnyRecord = { ...(theme.components as AnyRecord) };

  // 1) scale → :root via MuiCssBaseline (needs <CssBaseline/>), layer-preserving
  const baseline = components.MuiCssBaseline?.styleOverrides;
  const baselineObj: AnyRecord = baseline && typeof baseline === 'object' ? baseline : {};
  components.MuiCssBaseline = {
    ...components.MuiCssBaseline,
    styleOverrides: {
      ...baselineObj,
      ':root': { ...(baselineObj[':root'] as AnyRecord), ...p.scale },
    },
  };

  // 2) component overrides — flat array-form slot merge (density wins by order,
  //    the app's own styleOverrides/variants are kept as the leading layer).
  //    NEVER deepmerge here: createTheme(theme, {components}) would replace the
  //    preset's variants arrays.
  for (const [name, def] of Object.entries(p.components)) {
    const prev: AnyRecord = components[name] ?? {};
    const slots: AnyRecord = { ...prev.styleOverrides };
    for (const [slot, layer] of Object.entries((def as AnyRecord).styleOverrides)) {
      const layers = Array.isArray(layer) ? layer : [layer];
      slots[slot] = [prev.styleOverrides?.[slot], ...layers].filter(Boolean);
    }
    components[name] = { ...prev, styleOverrides: slots };
  }

  return createTheme({
    ...theme,
    typography: mergeTypography(theme.typography as AnyRecord, p.typography),
    shape: { ...theme.shape, ...p.shape },
    components,
  } as AnyRecord);
}

export function enhanceCompactDensity(theme: Theme): Theme {
  return enhance(theme, compact);
}
export function enhanceNormalDensity(theme: Theme): Theme {
  return enhance(theme, normal);
}
export function enhanceComfortDensity(theme: Theme): Theme {
  return enhance(theme, comfort);
}
"
`;
