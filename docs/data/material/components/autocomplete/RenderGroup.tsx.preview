<Autocomplete
  options={options}
  groupBy={(option) => option.continent}
  sx={{ width: 300 }}
  renderInput={(params) => <TextField {...params} label="Choose a country" />}
  renderGroup={(params) => (
    <Group key={params.key}>
      <GroupHeader>{params.group}</GroupHeader>
      <GroupItems>{params.children}</GroupItems>
    </Group>
  )}
/>