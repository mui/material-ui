<FormControlLabel
  control={<Switch onChange={handleChange} />}
  label="Toggle RTL"
/>
<CacheProvider value={rtl ? rtlCache : ltrCache}>
  <Box sx={{ flexGrow: 1, mx: 2 }} dir={rtl ? 'rtl' : undefined}>
    <Normal>RTL normal behavior</Normal>
    <Noflip>RTL noflip</Noflip>
  </Box>
</CacheProvider>