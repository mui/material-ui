import { writeFileSync } from 'node:fs';
import { join, resolve } from 'node:path';

import createTheme from '../src/styles/createTheme.js';
import generateThemeCss from '../src/styles/generateThemeCss.js';

const outFile = process.env.OUTFILE
  ? resolve(process.env.OUTFILE)
  : join(process.cwd(), 'packages/mui-material/default-theme.css');

const theme = createTheme({
  cssVariables: { colorSchemeSelector: 'data-mui-color-scheme' },
  colorSchemes: { light: true, dark: true },
});

const css = generateThemeCss(theme);

const header = [
  '/*',
  ' * MUI default theme - generated by scripts/buildDefaultThemeCss.mts',
  ' * DO NOT EDIT MANUALLY.',
  ' *',
  ' * Import this file once at the root of your application:',
  ' *   import "@mui/material/default-theme.css";',
  ' *',
  ' * Then toggle dark mode by setting:',
  ' *   document.documentElement.setAttribute("data-mui-color-scheme", "dark");',
  ' */',
  '',
].join('\n');

writeFileSync(outFile, header + css, 'utf8');
// eslint-disable-next-line no-console
console.log(`Written ${outFile}`);
