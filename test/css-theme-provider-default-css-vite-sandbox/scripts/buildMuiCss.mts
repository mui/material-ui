import { writeFile } from 'node:fs/promises';
import path from 'node:path';
import { fileURLToPath } from 'node:url';
import { generateTailwindThemeCss } from '@mui/material-css-tools';
import { createTheme } from '@mui/material/styles';

const dirname = path.dirname(fileURLToPath(import.meta.url));
const srcRoot = path.resolve(dirname, '../src');
const theme = createTheme();

await writeFile(
  path.join(srcRoot, 'tailwind.css'),
  [
    '/* Generated by scripts/buildMuiCss.mts. */',
    '@layer theme, base, mui, components, utilities;',
    '',
    "@import 'tailwindcss/theme.css' layer(theme);",
    "@import 'tailwindcss/utilities.css' layer(utilities);",
    "@import './tailwind-theme.css';",
    '',
  ].join('\n'),
);

await writeFile(
  path.join(srcRoot, 'tailwind-theme.css'),
  ['/* Generated by scripts/buildMuiCss.mts. */', generateTailwindThemeCss(theme), ''].join('\n\n'),
);
