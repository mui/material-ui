{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "types": ["vitest/globals"]
  },
  "include": ["e2e/**/*", "integration/**/*", "regressions/**/*"],
  "exclude": [
    "node_modules",
    "regressions/build/**/*",
    "vitest.config.ts",
    "e2e/vite.config.mts",
    "regressions/vite.config.mts"
  ]
}
