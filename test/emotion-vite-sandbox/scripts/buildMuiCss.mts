import { writeFile } from 'node:fs/promises';
import path from 'node:path';
import { fileURLToPath } from 'node:url';
import { createTheme, generateBreakpointCustomMedia } from '@mui/material/styles';

const dirname = path.dirname(fileURLToPath(import.meta.url));
const appRoot = path.resolve(dirname, '..');
const srcRoot = path.resolve(dirname, '../src');
const customBreakpoints = {
  values: { xs: 0, sm: 720, md: 900, lg: 1200, xl: 1536 },
};
const theme = createTheme({ breakpoints: customBreakpoints });

await writeFile(
  path.join(srcRoot, 'mui.css'),
  [
    '/* Generated by scripts/buildMuiCss.mts. */',
    "@import '@mui/material/components-source.css';",
    '',
    generateBreakpointCustomMedia(theme),
    '',
    '@tailwind base;',
    '@tailwind components;',
    '@tailwind utilities;',
    '',
  ].join('\n'),
);

await writeFile(
  path.join(appRoot, 'tailwind.config.cjs'),
  [
    '/* Generated by scripts/buildMuiCss.mts. */',
    "const { createTheme, createTailwindPreset } = require('@mui/material/styles');",
    '',
    `const customBreakpoints = ${JSON.stringify(customBreakpoints, null, 2)};`,
    '',
    'module.exports = {',
    "  content: ['./index.html', './src/**/*.{ts,tsx}'],",
    '  presets: [createTailwindPreset(createTheme({ breakpoints: customBreakpoints }))],',
    '};',
    '',
  ].join('\n'),
);
